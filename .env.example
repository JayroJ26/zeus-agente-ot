# Credenciales y configuración de Zeus.
# Copia este archivo como  .env  y rellena los valores reales.
# El .env NUNCA se sube al repositorio (ya está en .gitignore).

# --- Cerebro: API de Claude (solo si Zeus razona de forma autónoma) ---
# Obtén la clave en https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Correo de Zeus (cuenta de Gmail) ---
# App Password de 16 caracteres, SIN espacios
ZEUS_EMAIL=zeus.mantenimiento@gmail.com
ZEUS_APP_PASSWORD=
IMAP_HOST=imap.gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Responsable de mantenimiento que recibe la OT en PDF (al crearla y finalizarla).
# Vacío = se envía a la propia cuenta de Zeus (útil para la demo).
OT_DESTINATARIO=

# --- Telegram (canal secundario, opcional) ---
# Token que te da @BotFather al crear el bot
TELEGRAM_BOT_TOKEN=
# Operadores autorizados: uno o varios chat_id separados por coma.
# Vacío = el bot acepta a cualquiera. Manda /id al bot para conocer tu chat_id.
TELEGRAM_CHAT_ID=
